#!/bin/bash

# 查看 GPU 运行进程的用户信息
# 默认紧凑输出，加 -l 或 --long 参数显示完整命令

LONG_MODE=${1:-""}

if [ "$LONG_MODE" = "-l" ] || [ "$LONG_MODE" = "--long" ]; then
    # 长模式：完整命令
    cmd_len=150
    separator="-------------------------------------------------------------------------------------------------------------------------------"
else
    # 默认：紧凑模式，约80字符宽度
    cmd_len=25
    separator="--------------------------------------------------------------------------------"
fi

# 使用 printf 格式化输出
format="%-3s %-7s %-12s %-6s %-4s %-4s %-5s %-11s %s\n"

# 打印表头
printf "$format" "GPU" "PID" "USER" "GMEM" "MEM" "CPU" "STAT" "TIME" "CMD"
echo "$separator"

# 使用 nvidia-smi 获取进程信息，并关联用户
nvidia-smi --query-compute-apps=pid,gpu_uuid,used_memory --format=csv,noheader,nounits 2>/dev/null | while read -r line; do
    pid=$(echo "$line" | cut -d',' -f1 | tr -d ' ')
    gpu_uuid=$(echo "$line" | cut -d',' -f2 | tr -d ' ')
    gpu_mem=$(echo "$line" | cut -d',' -f3 | tr -d ' ')

    # 根据 UUID 获取 GPU 编号
    gpu_id=$(nvidia-smi --query-gpu=index --id="$gpu_uuid" --format=csv,noheader 2>/dev/null | tr -d ' ')

    if [ -n "$pid" ] && [ "$pid" != "No running" ]; then
        # 获取进程用户
        user=$(ps -o user= -p "$pid" 2>/dev/null)
        # 获取 CPU 和内存占用
        cpu_mem=$(ps -o %cpu,%mem --no-headers -p "$pid" 2>/dev/null)
        cpu=$(echo "$cpu_mem" | awk '{print $1}')
        mem=$(echo "$cpu_mem" | awk '{print $2}')
        # 获取进程状态
        stat=$(ps -o stat= -p "$pid" 2>/dev/null | xargs)
        # 获取运行时间
        time=$(ps -o etime= -p "$pid" 2>/dev/null | xargs)
        # 获取启动命令并截断
        cmd=$(ps -o args= -p "$pid" 2>/dev/null | cut -c1-$cmd_len)

        if [ -n "$user" ]; then
            printf "$format" "$gpu_id" "$pid" "$user" "${gpu_mem}M" "$mem" "$cpu" "$stat" "$time" "$cmd"
        fi
    fi
done
